# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text diff=python
*.pyi text diff=python

# Documentation
*.md text diff=markdown
*.txt text

# Config files
*.json text
*.yml text
*.yaml text
*.toml text

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary

# Build artifacts
*.whl binary
*.tar.gz binary

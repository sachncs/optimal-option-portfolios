# Environment Configuration for oop
# Copy this file to .env and fill in values as needed.

# Random seed for deterministic execution
# Default: 7
# OOP_SEED=7

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
# OOP_LOG_LEVEL=INFO

# Output directory for reports and artifacts
# Default: artifacts
# OOP_OUTPUT_DIR=artifacts

# Optimization alpha parameter (must be between 0 and 0.5)
# Default: 0.05
# OOP_ALPHA=0.05
